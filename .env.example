ANTHROPIC_API_KEY=your_key_here

# --- Email notifications (optional) ---
# Works with Gmail (use an "app password", not your normal password),
# or any SMTP provider (SendGrid, Mailgun, your own mail server, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASSWORD=your_app_password_here
ALERT_EMAIL_TO=you@example.com

# --- Telegram notifications (optional) ---
# 1. Message @BotFather on Telegram, run /newbot, copy the token it gives you
# 2. Message your new bot at least once, then message @userinfobot to get your chat id
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
